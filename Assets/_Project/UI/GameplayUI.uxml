            <ui:Label text="Nội dung" name="Text" selectable="false" class="text" style="font-size: 16px; -unity-text-align: upper-left; flex-direction: row; justify-content: center; align-items: center; align-self: flex-start; position: absolute; right: 10px; bottom: 10px; width: 400px; height: 140px; border-left-color: rgba(242, 239, 0, 0); border-right-color: rgba(242, 239, 0, 0); border-top-color: rgba(242, 239, 0, 0); border-bottom-color: rgba(242, 239, 0, 0); border-top-width: 15px; border-right-width: 15px; border-bottom-width: 15px; border-left-width: 15px; background-image: url(&quot;project://database/Assets/_Project/Art/Resources/background/blue.png?fileID=2800000&amp;guid=9fa2d0effbfa7e04594d586d1534f927&amp;type=3#blue&quot;); opacity: 1; border-top-left-radius: 10px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-bottom-left-radius: 10px; -unity-slice-type: sliced; -unity-background-scale-mode: stretch-to-fill; background-position-x: center 0; white-space: normal; text-overflow: clip; transform-origin: center; visibility: visible;" />
            <ui:Label text="" name="StatusText" selectable="false" style="font-size: 14px; -unity-text-align: middle-left; position: absolute; left: 10px; bottom: 10px; width: 360px; height: 28px; color: rgb(255, 255, 255);" />
