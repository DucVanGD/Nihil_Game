            <ui:Button text="4" name="Card4" class="card" style="left: 470px; background-image: url(&quot;project://database/Assets/_Project/Art/Resources/background/Card/Healing.png?fileID=2800000&amp;guid=6f804a1cce4bc4e4b854495ede2a05ad&amp;type=3#Healing&quot;);" />
